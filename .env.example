# GitHub API Token (required for fetching portfolio data)
# Create a classic personal access token at:
# https://github.com/settings/tokens/new?scopes=repo,read:user
# Then paste it below (no quotes needed):
GITHUB_TOKEN=

# Deployment URL (optional — your Vercel project URL)
# NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app
